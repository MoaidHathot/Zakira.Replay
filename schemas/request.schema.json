{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zakira.local/replay/schemas/request.schema.json",
  "title": "Zakira.Replay Analyze Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source",
    "visionInstruction",
    "ocrInstruction",
    "includeTranscript",
    "frameCount",
    "extractAudio",
    "useSpeechToText",
    "useOcr",
    "useVision",
    "maxAiFrames",
    "model",
    "llmProvider",
    "force",
    "useCache",
    "frameStrategy"
  ],
  "properties": {
    "source": { "type": "string", "minLength": 1 },
    "visionInstruction": { "type": "string" },
    "ocrInstruction": { "type": "string" },
    "includeTranscript": { "type": "boolean" },
    "frameCount": { "type": "integer", "minimum": 0 },
    "runId": { "type": ["string", "null"] },
    "extractAudio": { "type": "boolean" },
    "useSpeechToText": { "type": "boolean" },
    "useOcr": { "type": "boolean" },
    "useVision": { "type": "boolean" },
    "maxAiFrames": { "type": "integer", "minimum": 0 },
    "model": { "type": "string" },
    "llmProvider": { "type": "string", "enum": ["github-copilot", "openai", "azure-openai"] },
    "force": { "type": "boolean" },
    "useCache": { "type": "boolean" },
    "frameStrategy": { "type": "string", "enum": ["interval", "scene", "every-frame"] },
    "cookiesPath": { "type": ["string", "null"] },
    "cookiesFromBrowser": { "type": ["string", "null"] },
    "captionLanguages": {
      "type": ["array", "null"],
      "items": { "type": "string", "minLength": 1 }
    },
    "slideGrouping": { "type": ["boolean", "null"] },
    "slideHashDistance": {
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 64
    },
    "framesPerMinute": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "sceneSafetyCap": {
      "type": ["integer", "null"],
      "minimum": 1
    }
  }
}
