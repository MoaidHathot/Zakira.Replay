{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zakira.local/replay/schemas/queue-run-result.schema.json",
  "title": "Zakira.Replay Queue Run Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "queueId", "queueDirectory", "startedAt", "completedAt", "concurrency", "retries", "attempted", "succeeded", "failed", "pending", "jobs"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "queueId": { "type": "string" },
    "queueDirectory": { "type": "string" },
    "startedAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": "string", "format": "date-time" },
    "concurrency": { "type": "integer", "minimum": 1 },
    "retries": { "type": "integer", "minimum": 0 },
    "attempted": { "type": "integer", "minimum": 0 },
    "succeeded": { "type": "integer", "minimum": 0 },
    "failed": { "type": "integer", "minimum": 0 },
    "pending": { "type": "integer", "minimum": 0 },
    "jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["jobId", "status", "attempts"],
        "properties": {
          "jobId": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "running", "succeeded", "failed"] },
          "attempts": { "type": "integer", "minimum": 0 },
          "runId": { "type": ["string", "null"] },
          "artifactDirectory": { "type": ["string", "null"] },
          "error": { "type": ["string", "null"] }
        }
      }
    }
  }
}
