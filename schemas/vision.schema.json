{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zakira.local/replay/schemas/vision.schema.json",
  "title": "Zakira.Replay Vision Frame Result",
  "description": "Per-frame structured vision analysis. Stored both inside evidence.json and as vision/{frameId}.json for direct orchestrator access. The structured field is null when the model returned non-JSON; in that case the run carries a VISION_PARSE_FALLBACK warning.",
  "type": "object",
  "additionalProperties": false,
  "required": ["frameId", "framePath", "timestampSeconds", "timestampLabel", "description"],
  "properties": {
    "frameId": { "type": "string", "minLength": 1 },
    "framePath": { "type": "string", "minLength": 1 },
    "timestampSeconds": { "type": "number", "minimum": 0 },
    "timestampLabel": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "slideId": { "type": ["string", "null"] },
    "structured": {
      "anyOf": [
        { "type": "null" },
        { "$ref": "#/$defs/visionStructured" }
      ]
    },
    "provider": {
      "description": "Vision provider that produced this result. `copilot` (LLM-backed) or `local` (LocalOnnxVisionProvider). Older runs may omit the field.",
      "type": ["string", "null"]
    }
  },
  "$defs": {
    "visionStructured": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "bullets", "codeBlocks", "charts", "uiElements", "freeText"],
      "properties": {
        "kind": { "type": "string", "enum": ["slide", "ui", "code", "diagram", "chart", "dashboard", "other"] },
        "title": { "type": ["string", "null"] },
        "bullets": { "type": "array", "items": { "type": "string" } },
        "codeBlocks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text"],
            "properties": {
              "language": { "type": ["string", "null"] },
              "text": { "type": "string", "minLength": 1 }
            }
          }
        },
        "charts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "title": { "type": ["string", "null"] },
              "axes": { "type": "array", "items": { "type": "string" } },
              "series": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "uiElements": { "type": "array", "items": { "type": "string" } },
        "freeText": { "type": "string" }
      }
    }
  }
}
