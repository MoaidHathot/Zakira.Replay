{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zakira.local/replay/schemas/evidence-aligned.schema.json",
  "title": "Zakira.Replay Evidence Alignment",
  "description": "Cross-modal alignment view built by EvidenceAlignmentService. Pure rearrangement of evidence.json + chapters/chapters.json. Two files share this schema; the `view` field discriminates: `by-chapter` (chapters[] populated, slides[] empty) or `by-slide` (slides[] populated, chapters[] empty).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "runId", "createdAt", "view"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "0.8" },
    "runId": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "view": { "type": "string", "enum": ["by-chapter", "by-slide"] },
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["chapterIndex", "startSeconds", "endSeconds", "timestamp", "endTimestamp", "slideIds", "transcriptSegmentIds", "speakers", "ocrFrameIds", "visionFrameIds"],
        "properties": {
          "chapterIndex": { "type": "integer", "minimum": 0 },
          "startSeconds": { "type": "number", "minimum": 0 },
          "endSeconds": { "type": "number", "minimum": 0 },
          "timestamp": { "type": "string", "minLength": 1 },
          "endTimestamp": { "type": "string", "minLength": 1 },
          "slideIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "transcriptSegmentIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "speakers": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["speakerId", "segmentCount", "totalSeconds"],
              "properties": {
                "speakerId": { "type": "string", "minLength": 1 },
                "segmentCount": { "type": "integer", "minimum": 0 },
                "totalSeconds": { "type": "number", "minimum": 0 }
              }
            }
          },
          "ocrFrameIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "visionFrameIds": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "slides": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slideId", "firstSeenSeconds", "lastSeenSeconds", "windowStartSeconds", "windowEndSeconds", "firstSeenLabel", "lastSeenLabel", "primaryFrameId", "frameIds", "transcriptSegmentIds", "speakers", "chapterIndices"],
        "properties": {
          "slideId": { "type": "string", "minLength": 1 },
          "firstSeenSeconds": { "type": "number", "minimum": 0 },
          "lastSeenSeconds": { "type": "number", "minimum": 0 },
          "windowStartSeconds": { "type": "number", "minimum": 0 },
          "windowEndSeconds": { "type": "number", "minimum": 0 },
          "firstSeenLabel": { "type": "string", "minLength": 1 },
          "lastSeenLabel": { "type": "string", "minLength": 1 },
          "primaryFrameId": { "type": "string", "minLength": 1 },
          "frameIds": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "ocr": {
            "anyOf": [
              { "type": "null" },
              { "type": "object" }
            ]
          },
          "vision": {
            "anyOf": [
              { "type": "null" },
              { "type": "object" }
            ]
          },
          "transcriptSegmentIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "speakers": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["speakerId", "segmentCount", "totalSeconds"],
              "properties": {
                "speakerId": { "type": "string", "minLength": 1 },
                "segmentCount": { "type": "integer", "minimum": 0 },
                "totalSeconds": { "type": "number", "minimum": 0 }
              }
            }
          },
          "chapterIndices": { "type": "array", "items": { "type": "integer", "minimum": 0 } }
        }
      }
    }
  }
}
