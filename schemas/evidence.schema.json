{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zakira.local/replay/schemas/evidence.schema.json",
  "title": "Zakira.Replay Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "source",
    "visionInstruction",
    "ocrInstruction",
    "runId",
    "transcript",
    "frames",
    "slides",
    "ocr",
    "vision",
    "speakers",
    "warnings"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "0.7" },
    "source": { "type": "string", "minLength": 1 },
    "visionInstruction": { "type": "string" },
    "ocrInstruction": { "type": "string" },
    "runId": { "type": "string", "minLength": 1 },
    "title": { "type": ["string", "null"] },
    "webpageUrl": { "type": ["string", "null"] },
    "durationSeconds": { "type": ["number", "null"], "minimum": 0 },
    "audioPath": { "type": ["string", "null"] },
    "transcript": {
      "type": "array",
      "items": { "$ref": "#/$defs/transcriptSegment" }
    },
    "frames": {
      "type": "array",
      "items": { "$ref": "#/$defs/frameArtifact" }
    },
    "slides": {
      "type": "array",
      "items": { "$ref": "#/$defs/slideArtifact" }
    },
    "ocr": {
      "type": "array",
      "items": { "$ref": "#/$defs/ocrFrameResult" }
    },
    "vision": {
      "type": "array",
      "items": { "$ref": "#/$defs/visionFrameResult" }
    },
    "speakers": {
      "type": "array",
      "items": { "$ref": "#/$defs/speakerSummary" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/replayWarning" }
    }
  },
  "$defs": {
    "transcriptSegment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "id": { "type": ["string", "null"] },
        "startSeconds": { "type": ["number", "null"], "minimum": 0 },
        "endSeconds": { "type": ["number", "null"], "minimum": 0 },
        "timestamp": { "type": ["string", "null"] },
        "text": { "type": "string" },
        "speakerId": { "type": ["string", "null"] },
        "speakerDisplayName": { "type": ["string", "null"] }
      }
    },
    "frameArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "timestampSeconds", "timestampLabel"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "timestampSeconds": { "type": "number", "minimum": 0 },
        "timestampLabel": { "type": "string", "minLength": 1 },
        "perceptualHash": { "type": ["string", "null"] }
      }
    },
    "slideArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "firstSeenSeconds", "lastSeenSeconds", "firstSeenLabel", "lastSeenLabel", "primaryFrameId", "frameIds"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "firstSeenSeconds": { "type": "number", "minimum": 0 },
        "lastSeenSeconds": { "type": "number", "minimum": 0 },
        "firstSeenLabel": { "type": "string", "minLength": 1 },
        "lastSeenLabel": { "type": "string", "minLength": 1 },
        "primaryFrameId": { "type": "string", "minLength": 1 },
        "frameIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "perceptualHash": { "type": ["string", "null"] }
      }
    },
    "ocrFrameResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frameId", "framePath", "timestampSeconds", "timestampLabel", "text"],
      "properties": {
        "frameId": { "type": "string", "minLength": 1 },
        "framePath": { "type": "string", "minLength": 1 },
        "timestampSeconds": { "type": "number", "minimum": 0 },
        "timestampLabel": { "type": "string", "minLength": 1 },
        "text": { "type": "string" },
        "slideId": { "type": ["string", "null"] },
        "structured": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/ocrStructured" }
          ]
        }
      }
    },
    "visionFrameResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frameId", "framePath", "timestampSeconds", "timestampLabel", "description"],
      "properties": {
        "frameId": { "type": "string", "minLength": 1 },
        "framePath": { "type": "string", "minLength": 1 },
        "timestampSeconds": { "type": "number", "minimum": 0 },
        "timestampLabel": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "slideId": { "type": ["string", "null"] },
        "structured": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/visionStructured" }
          ]
        }
      }
    },
    "ocrStructured": {
      "type": "object",
      "additionalProperties": false,
      "required": ["freeText", "lines", "tables"],
      "properties": {
        "freeText": { "type": "string" },
        "lines": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tables": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["headers", "rows"],
            "properties": {
              "headers": { "type": "array", "items": { "type": "string" } },
              "rows": {
                "type": "array",
                "items": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "visionStructured": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "bullets", "codeBlocks", "charts", "uiElements", "freeText"],
      "properties": {
        "kind": { "type": "string", "enum": ["slide", "ui", "code", "diagram", "chart", "dashboard", "other"] },
        "title": { "type": ["string", "null"] },
        "bullets": { "type": "array", "items": { "type": "string" } },
        "codeBlocks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text"],
            "properties": {
              "language": { "type": ["string", "null"] },
              "text": { "type": "string", "minLength": 1 }
            }
          }
        },
        "charts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "title": { "type": ["string", "null"] },
              "axes": { "type": "array", "items": { "type": "string" } },
              "series": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "uiElements": { "type": "array", "items": { "type": "string" } },
        "freeText": { "type": "string" }
      }
    },
    "speakerSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "segmentCount", "totalSeconds"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "displayName": { "type": ["string", "null"] },
        "segmentCount": { "type": "integer", "minimum": 0 },
        "totalSeconds": { "type": "number", "minimum": 0 },
        "firstSeenSeconds": { "type": ["number", "null"], "minimum": 0 },
        "lastSeenSeconds": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "replayWarning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "severity"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "source": { "type": ["string", "null"] },
        "severity": { "type": "string", "enum": ["info", "warning", "error"] }
      }
    }
  }
}
