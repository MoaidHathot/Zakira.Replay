{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zakira.local/replay/schemas/search-index.schema.json",
  "title": "Zakira.Replay JSON Search Index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "runId", "createdAt", "documentCount", "documents"],
  "properties": {
    "schemaVersion": { "type": "string", "enum": ["0.1", "0.2"] },
    "runId": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "documentCount": { "type": "integer", "minimum": 0 },
    "embeddingModel": {
      "type": ["string", "null"],
      "description": "Identity of the search-embedding model the documents were embedded with (e.g. 'bge-small-en-v1.5'). Null for the json/sqlite backends, which don't store dense vectors."
    },
    "embeddingModelKind": {
      "type": ["string", "null"],
      "enum": ["bert", "bge", "e5", null],
      "description": "Embedding scheme family. Null when no embedding model was used."
    },
    "embeddingDimensions": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "sourceUrl": {
      "description": "Original session URL (evidence.WebpageUrl ?? evidence.Source) captured at build time so query results can carry deep links per match. Null when no URL was on file.",
      "type": ["string", "null"]
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "text", "weights"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "text": { "type": "string" },
          "startSeconds": { "type": ["number", "null"], "minimum": 0 },
          "endSeconds": { "type": ["number", "null"], "minimum": 0 },
          "timestamp": { "type": ["string", "null"] },
          "path": { "type": ["string", "null"] },
          "weights": {
            "type": "object",
            "additionalProperties": { "type": "number" }
          }
        }
      }
    }
  }
}

