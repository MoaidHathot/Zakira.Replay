{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zakira.local/replay/schemas/clip.schema.json",
  "title": "Zakira.Replay Clip Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "source", "runId", "start", "end", "clipPath", "warnings"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "0.2" },
    "source": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "start": { "type": "string", "minLength": 1 },
    "end": { "type": "string", "minLength": 1 },
    "clipPath": { "type": "string", "minLength": 1 },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/replayWarning" }
    }
  },
  "$defs": {
    "replayWarning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "severity"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "source": { "type": ["string", "null"] },
        "severity": { "type": "string", "enum": ["info", "warning", "error"] }
      }
    }
  }
}
