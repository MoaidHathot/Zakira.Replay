{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zakira.local/replay/schemas/manifest.schema.json",
  "title": "Zakira.Replay Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "source",
    "visionInstruction",
    "ocrInstruction",
    "createdAt",
    "runId",
    "evidencePath",
    "frames",
    "warnings"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "0.8" },
    "source": { "type": "string", "minLength": 1 },
    "visionInstruction": { "type": "string" },
    "ocrInstruction": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "runId": { "type": "string", "minLength": 1 },
    "title": { "type": ["string", "null"] },
    "webpageUrl": { "type": ["string", "null"] },
    "duration": { "type": ["string", "null"] },
    "audioPath": { "type": ["string", "null"] },
    "transcriptPath": { "type": ["string", "null"] },
    "ocrPath": { "type": ["string", "null"] },
    "visionPath": { "type": ["string", "null"] },
    "evidencePath": { "type": ["string", "null"] },
    "frames": {
      "type": "array",
      "items": { "$ref": "#/$defs/frameArtifact" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/replayWarning" }
    }
  },
  "$defs": {
    "frameArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "timestampSeconds", "timestampLabel"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "timestampSeconds": { "type": "number", "minimum": 0 },
        "timestampLabel": { "type": "string", "minLength": 1 },
        "perceptualHash": { "type": ["string", "null"] },
        "width": { "type": ["integer", "null"], "minimum": 0 },
        "height": { "type": ["integer", "null"], "minimum": 0 },
        "originalPath": {
          "description": "Relative path of the source frame this entry's `path` is derived from (set when a preprocessing step, e.g. smart-crop, replaced the frame on disk).",
          "type": ["string", "null"]
        },
        "crop": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/frameCropBox" }
          ]
        }
      }
    },
    "frameCropBox": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height", "source"],
      "properties": {
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "source": {
          "description": "Identifier of the algorithm that produced this crop (e.g. `smart-crop-auto`, `smart-crop-teams`).",
          "type": "string",
          "minLength": 1
        }
      }
    },
    "replayWarning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "severity"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "source": { "type": ["string", "null"] },
        "severity": { "type": "string", "enum": ["info", "warning", "error"] }
      }
    }
  }
}
