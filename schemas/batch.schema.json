{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zakira.local/replay/schemas/batch.schema.json",
  "title": "Zakira.Replay Batch Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["items"],
  "properties": {
    "batchId": { "type": ["string", "null"] },
    "visionInstruction": { "type": ["string", "null"] },
    "ocrInstruction": { "type": ["string", "null"] },
    "frames": { "type": ["integer", "null"], "minimum": 0 },
    "includeTranscript": { "type": ["boolean", "null"] },
    "extractAudio": { "type": ["boolean", "null"] },
    "useSpeechToText": { "type": ["boolean", "null"] },
    "useOcr": { "type": ["boolean", "null"] },
    "useVision": { "type": ["boolean", "null"] },
    "maxAiFrames": { "type": ["integer", "null"], "minimum": 0 },
    "model": { "type": ["string", "null"] },
    "llmProvider": { "type": ["string", "null"] },
    "useCache": { "type": ["boolean", "null"] },
    "frameStrategy": { "type": ["string", "null"] },
    "cookiesPath": { "type": ["string", "null"] },
    "cookiesFromBrowser": { "type": ["string", "null"] },
    "captionLanguages": {
      "type": ["array", "null"],
      "items": { "type": "string", "minLength": 1 }
    },
    "slideGrouping": { "type": ["boolean", "null"] },
    "slideHashDistance": { "type": ["integer", "null"], "minimum": 0, "maximum": 64 },
    "framesPerMinute": { "type": ["integer", "null"], "minimum": 0 },
    "sceneSafetyCap": { "type": ["integer", "null"], "minimum": 1 },
    "ocrProvider": { "type": ["string", "null"], "enum": ["copilot", "local", null] },
    "smartCrop": { "type": ["boolean", "null"] },
    "smartCropProfile": { "type": ["string", "null"] },
    "captureMode": { "type": ["string", "null"], "enum": ["auto", "ytdlp", "browser", null] },
    "authProfile": { "type": ["string", "null"] },
    "useDiarization": { "type": ["boolean", "null"] },
    "numSpeakers": { "type": ["integer", "null"], "minimum": 1 },
    "diarizationThreshold": { "type": ["number", "null"], "exclusiveMinimum": 0 },
    "continueOnError": { "type": "boolean" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source"],
        "properties": {
          "source": { "type": "string", "minLength": 1 },
          "visionInstruction": { "type": ["string", "null"] },
          "ocrInstruction": { "type": ["string", "null"] },
          "frames": { "type": ["integer", "null"], "minimum": 0 },
          "includeTranscript": { "type": ["boolean", "null"] },
          "extractAudio": { "type": ["boolean", "null"] },
          "useSpeechToText": { "type": ["boolean", "null"] },
          "useOcr": { "type": ["boolean", "null"] },
          "useVision": { "type": ["boolean", "null"] },
          "maxAiFrames": { "type": ["integer", "null"], "minimum": 0 },
          "model": { "type": ["string", "null"] },
          "llmProvider": { "type": ["string", "null"] },
          "runId": { "type": ["string", "null"] },
          "useCache": { "type": ["boolean", "null"] },
          "frameStrategy": { "type": ["string", "null"] },
          "cookiesPath": { "type": ["string", "null"] },
          "cookiesFromBrowser": { "type": ["string", "null"] },
          "captionLanguages": {
            "type": ["array", "null"],
            "items": { "type": "string", "minLength": 1 }
          },
          "slideGrouping": { "type": ["boolean", "null"] },
          "slideHashDistance": { "type": ["integer", "null"], "minimum": 0, "maximum": 64 },
          "framesPerMinute": { "type": ["integer", "null"], "minimum": 0 },
          "sceneSafetyCap": { "type": ["integer", "null"], "minimum": 1 },
          "ocrProvider": { "type": ["string", "null"], "enum": ["copilot", "local", null] },
          "smartCrop": { "type": ["boolean", "null"] },
          "smartCropProfile": { "type": ["string", "null"] },
          "captureMode": { "type": ["string", "null"], "enum": ["auto", "ytdlp", "browser", null] },
          "authProfile": { "type": ["string", "null"] },
          "useDiarization": { "type": ["boolean", "null"] },
          "numSpeakers": { "type": ["integer", "null"], "minimum": 1 },
          "diarizationThreshold": { "type": ["number", "null"], "exclusiveMinimum": 0 }
        }
      }
    }
  }
}
