{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zakira.local/replay/schemas/frame-capture.schema.json",
  "title": "Zakira.Replay Frame Capture Manifest",
  "description": "Minimal manifest written by FrameCaptureService for ad-hoc frame extraction. Distinct from manifest.schema.json (full analyze) via the `kind` discriminator.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "source", "runId", "createdAt", "request", "frames", "warnings"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "0.1" },
    "kind": { "type": "string", "const": "frame-capture" },
    "source": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "request": { "$ref": "#/$defs/requestSummary" },
    "frames": {
      "type": "array",
      "items": { "$ref": "#/$defs/frameArtifact" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/replayWarning" }
    }
  },
  "$defs": {
    "requestSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["timestamps", "range"] },
        "timestamps": {
          "type": ["array", "null"],
          "items": { "type": "string", "minLength": 1 }
        },
        "rangeStart": { "type": ["string", "null"] },
        "rangeEnd": { "type": ["string", "null"] },
        "rangeCount": { "type": ["integer", "null"], "minimum": 1 },
        "rangeStrategy": {
          "type": ["string", "null"],
          "enum": ["interval", "scene", null]
        },
        "maxLongEdgePixels": { "type": ["integer", "null"], "minimum": 16 },
        "jpegQuality": { "type": ["integer", "null"], "minimum": 1, "maximum": 100 },
        "computePerceptualHash": { "type": "boolean" }
      }
    },
    "frameArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "timestampSeconds", "timestampLabel"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "timestampSeconds": { "type": "number", "minimum": 0 },
        "timestampLabel": { "type": "string", "minLength": 1 },
        "perceptualHash": { "type": ["string", "null"] },
        "width": { "type": ["integer", "null"], "minimum": 0 },
        "height": { "type": ["integer", "null"], "minimum": 0 },
        "originalPath": { "type": ["string", "null"] },
        "crop": { "type": ["object", "null"] }
      }
    },
    "replayWarning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "severity"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "source": { "type": ["string", "null"] },
        "severity": { "type": "string", "enum": ["info", "warning", "error"] }
      }
    }
  }
}
