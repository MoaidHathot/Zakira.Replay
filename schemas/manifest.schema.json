{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zakira.local/replay/schemas/manifest.schema.json",
  "title": "Zakira.Replay Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "source",
    "visionInstruction",
    "ocrInstruction",
    "createdAt",
    "runId",
    "evidencePath",
    "frames",
    "warnings"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "0.8" },
    "source": { "type": "string", "minLength": 1 },
    "visionInstruction": { "type": "string" },
    "ocrInstruction": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "runId": { "type": "string", "minLength": 1 },
    "title": { "type": ["string", "null"] },
    "webpageUrl": { "type": ["string", "null"] },
    "duration": { "type": ["string", "null"] },
    "audioPath": { "type": ["string", "null"] },
    "transcriptPath": { "type": ["string", "null"] },
    "ocrPath": { "type": ["string", "null"] },
    "visionPath": { "type": ["string", "null"] },
    "evidencePath": { "type": ["string", "null"] },
    "frames": {
      "type": "array",
      "items": { "$ref": "#/$defs/frameArtifact" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/replayWarning" }
    },
    "timings": {
      "description": "Wall-clock seconds per pipeline stage. Stages absent from the map did not run. Stage names are open (orchestrators must tolerate unknown keys); see RunTimingStages for the canonical set used by AnalysisPipeline.",
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["totalSeconds", "stages"],
          "properties": {
            "totalSeconds": { "type": "number", "minimum": 0 },
            "stages": {
              "type": "object",
              "additionalProperties": { "type": "number", "minimum": 0 }
            }
          }
        }
      ]
    },
    "secondaryTranscripts": {
      "description": "Additional-language transcripts written alongside transcriptPath when the run was configured with --secondary-transcripts. Empty/absent when only the primary transcript was produced.",
      "anyOf": [
        { "type": "null" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/secondaryTranscriptArtifact" }
        }
      ]
    },
    "sessionMetadata": {
      "description": "Deterministic source-page-derived metadata about the session (title, speakers, abstract, etc.) extracted from JSON-LD/OpenGraph/HTML during browser capture. Null when not browser-captured or when nothing was parseable.",
      "anyOf": [
        { "type": "null" },
        { "$ref": "#/$defs/sessionMetadata" }
      ]
    }
  },
  "$defs": {
    "sessionMetadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] },
        "sessionCode": { "type": ["string", "null"] },
        "track": { "type": ["string", "null"] },
        "level": { "type": ["string", "null"] },
        "publishedAt": { "type": ["string", "null"] },
        "speakers": { "type": ["array", "null"], "items": { "type": "string", "minLength": 1 } },
        "products": { "type": ["array", "null"], "items": { "type": "string", "minLength": 1 } },
        "tags": { "type": ["array", "null"], "items": { "type": "string", "minLength": 1 } },
        "sourceUrl": { "type": ["string", "null"] },
        "sources": {
          "type": ["array", "null"],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["strategy", "fields"],
            "properties": {
              "strategy": { "type": "string", "minLength": 1 },
              "fields": { "type": "array", "items": { "type": "string", "minLength": 1 } }
            }
          }
        }
      }
    },
    "secondaryTranscriptArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "markdownPath", "sourcePath"],
      "properties": {
        "language": { "type": "string", "minLength": 1 },
        "markdownPath": { "type": "string", "minLength": 1 },
        "sourcePath": { "type": "string", "minLength": 1 }
      }
    },
    "frameArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "timestampSeconds", "timestampLabel"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "timestampSeconds": { "type": "number", "minimum": 0 },
        "timestampLabel": { "type": "string", "minLength": 1 },
        "perceptualHash": { "type": ["string", "null"] },
        "width": { "type": ["integer", "null"], "minimum": 0 },
        "height": { "type": ["integer", "null"], "minimum": 0 },
        "originalPath": {
          "description": "Relative path of the source frame this entry's `path` is derived from (set when a preprocessing step, e.g. smart-crop, replaced the frame on disk).",
          "type": ["string", "null"]
        },
        "crop": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/frameCropBox" }
          ]
        }
      }
    },
    "frameCropBox": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height", "source"],
      "properties": {
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "source": {
          "description": "Identifier of the algorithm that produced this crop (e.g. `smart-crop-auto`, `smart-crop-teams`).",
          "type": "string",
          "minLength": 1
        }
      }
    },
    "replayWarning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "severity"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "source": { "type": ["string", "null"] },
        "severity": { "type": "string", "enum": ["info", "warning", "error"] }
      }
    }
  }
}
